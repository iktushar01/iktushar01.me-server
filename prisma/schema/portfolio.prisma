model Project {
  id           String   @id @default(uuid())
  title        String
  tag          String
  description  String   @db.Text
  images       String[]
  technologies String[]
  liveLink      String?
  frontendLink  String?
  backendLink   String?
  demoVideoLink String?
  challenges   String[]
  improvements String[]
  sortOrder    Int      @default(0)
  isPublished  Boolean  @default(true)
  isDeleted    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isPublished, sortOrder])
  @@map("projects")
}

model Certificate {
  id            String   @id @default(uuid())
  title         String
  issuer        String
  date          String
  description   String   @db.Text
  image         String
  skills        String[]
  credentialUrl String?
  sortOrder     Int      @default(0)
  isPublished   Boolean  @default(true)
  isDeleted     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isPublished, sortOrder])
  @@map("certificates")
}

model Activity {
  id                String       @id @default(uuid())
  slug              String       @unique
  title             String
  type              ActivityType
  organizer         String
  date              String
  location          String?
  achievement       String?
  shortDescription  String       @db.Text
  fullDescription   String       @db.Text
  coverImage        String
  gallery           String[]
  role              String?
  techStack         String[]
  teamMembers       String[]
  timeline          Json?
  outcomes          String[]
  certificateImages String[]
  projectLink       String?
  githubLink        String?
  demoLink          String?
  eventWebsite      String?
  devpostLink       String?
  slidesLink        String?
  projectName       String?
  problemStatement  String?      @db.Text
  solutionOverview  String?      @db.Text
  demoVideoLink     String?
  teamSize          Int?
  awards            String[]
  sortOrder         Int          @default(0)
  isPublished       Boolean      @default(true)
  isDeleted         Boolean      @default(false)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([isPublished, sortOrder])
  @@map("activities")
}

model BlogPost {
  id          String     @id @default(uuid())
  title       String
  slug        String     @unique
  excerpt     String     @db.Text
  content     String     @db.Text
  coverImage  String
  category    String
  tags        String[]
  publishedAt DateTime?
  readingTime Int        @default(5)
  featured    Boolean    @default(false)
  author      String
  status      BlogStatus @default(DRAFT)
  isDeleted   Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([status, publishedAt])
  @@map("blog_posts")
}
